{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "dev:frontend": "next dev --turbopack",
    "dev:backend": "langgraphjs dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint && oxfmt --check",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "lint:fix": "oxlint --fix && oxfmt"
  },
  "dependencies": {
    "@assistant-ui/react": "latest",
    "@assistant-ui/react-langchain": "latest",
    "@assistant-ui/react-markdown": "latest",
    "@base-ui/react": "^1.6.0",
    "@langchain/anthropic": "^1.5.1",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/react": "^1.0.26",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "tw-shimmer": "^0.4.12",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@assistant-ui/next": "latest",
    "@langchain/core": "^1.2.3",
    "@langchain/langgraph-cli": "^1.4.2",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tailwindcss": "^4.3.2",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-7": "npm:typescript@^7.0.2"
  }
}
