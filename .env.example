# 域名
# 部署时应通过环境变量设置生产域名，
# 供 Traefik 转发流量并申请 TLS 证书
DOMAIN=localhost
# 用于测试本地 Traefik 配置
# DOMAIN=localhost.tiangolo.com

# 运行环境：local、staging、production
ENVIRONMENT=local

PROJECT_NAME="FastAPI React Project"
STACK_NAME=fastapi-react-project

# 后端
BACKEND_CORS_ORIGINS=
SECRET_KEY=changethis
FIRST_SUPERUSER_USERNAME=admin
FIRST_SUPERUSER_PASSWORD=changethis

# PostgreSQL 数据库
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Agent 模型
MODEL_API_KEY=
MODEL_PROVIDER=deepseek
MODEL_NAME=deepseek-v4-flash

# Exa MCP
EXA_API_KEY=

# 生图工具
IMAGE_API_KEY=
IMAGE_BASE_URL=https://nat.gbotai.cn/v1
IMAGE_MODEL=gpt-image-2

# E2B 沙箱
E2B_API_KEY=
E2B_TEMPLATE=

# 腾讯云 COS
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=
COS_BUCKET=

# Langfuse
LANGFUSE_BASE_URL=http://localhost:3002
LANGFUSE_PUBLIC_KEY=replace-me
LANGFUSE_SECRET_KEY=replace-me
LANGFUSE_SALT=replace-me
LANGFUSE_ENCRYPTION_KEY=replace-with-64-hex-characters
LANGFUSE_NEXTAUTH_SECRET=replace-me
LANGFUSE_POSTGRES_PASSWORD=replace-me
LANGFUSE_CLICKHOUSE_PASSWORD=replace-me
LANGFUSE_REDIS_PASSWORD=replace-me
LANGFUSE_MINIO_USER=minio
LANGFUSE_MINIO_PASSWORD=replace-me
LANGFUSE_INIT_USER_EMAIL=admin@localhost.local
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=replace-me

# 请替换为你自己的 Docker 镜像仓库地址
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
